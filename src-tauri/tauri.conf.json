{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LT AI Coach",
  "version": "1.1.3",
  "identifier": "com.lttools.lt-ai-coach",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LT AI Coach",
        "width": 1600,
        "height": 1000,
        "minWidth": 1600,
        "minHeight": 1000,
        "maxWidth": 1600,
        "maxHeight": 1000,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": false,
        "resizable": false,
        "maximizable": false
      },
      {
        "label": "overlay",
        "title": "LT AI Coach — Overlay",
        "backgroundColor": "#2b2b2b",
        "width": 980,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self'",
        "img-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "font-src": "'self'",
        "img-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": false
  }
}
